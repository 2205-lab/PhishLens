# PhishLens environment template — copy to .env and fill in real values
# NEVER commit the real .env file
# Requires: pip install python-dotenv

SPLUNK_HEC_URL=http://localhost:8088/services/collector
SPLUNK_HEC_TOKEN=your-hec-token-here
PHISHLENS_API=http://localhost:5000/score

# Splunk REST API (used by server.py for some dashboard queries)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USER=your-splunk-username
SPLUNK_PASS=your-splunk-password

# Optional — only needed if you want email inbox monitoring/alerts
EMAIL_HOST=imap.gmail.com
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your-gmail-app-password
ALERT_TO=soc-team@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ENABLE_EMAIL_ALERTS=false
