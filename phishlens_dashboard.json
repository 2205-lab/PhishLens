    "dataSources": {
        "ds_accuracy": {
            "options": {
                "query": "| makeresults | eval accuracy=88.29 | table accuracy",
                "queryParameters": {
                    "earliest": "-1m",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_action_queue": {
            "options": {
                "query": "index=main status=phishing (source=openphish_feed OR source=phishtank_feed) | dedup url | eval Risk=case(abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",abnormal_subdomain=1 OR domain_in_brand=1,\"HIGH\",phish_hints>0,\"MEDIUM\",1=1,\"LOW\") | eval Priority=case(Risk=\"CRITICAL\",\"1 - CRITICAL\",Risk=\"HIGH\",\"2 - HIGH\",Risk=\"MEDIUM\",\"3 - MEDIUM\",1=1,\"4 - LOW\") | eval Action_Required=case(Risk=\"CRITICAL\",\"FLAG for SOC + recommend block\",Risk=\"HIGH\",\"FLAG for SOC + investigate\",Risk=\"MEDIUM\",\"Monitor + flag for review\",1=1,\"Log only\") | eval Agent_Status=case(Risk=\"CRITICAL\" OR Risk=\"HIGH\",\"FLAGGED — Review in Extension\",Risk=\"MEDIUM\",\"Awaiting SOC decision\",1=1,\"Auto-allowed\") | sort Priority | head 15 | table Priority, url, Risk, Action_Required, Agent_Status, phish_hints",
                "queryParameters": {
                    "earliest": "-6h",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_active_threats": {
            "options": {
                "query": "index=main status=phishing (source=openphish_feed OR source=phishtank_feed) | eval Risk=case(abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",abnormal_subdomain=1 OR domain_in_brand=1,\"HIGH\",phish_hints>0,\"MEDIUM\",1=1,\"LOW\") | where Risk=\"CRITICAL\" OR Risk=\"HIGH\" | stats count as Active_Threats",
                "queryParameters": {
                    "earliest": "-1h",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_agent_decisions": {
            "options": {
                "query": "index=main (source=openphish_feed OR source=phishtank_feed OR source=api_submission) | eval Agent_Decision=case(risk_level=\"CRITICAL\" OR risk_level=\"HIGH\",\"FLAGGED — Review in Extension\",risk_level=\"MEDIUM\",\"Awaiting SOC decision\",status=\"legitimate\",\"Auto-allowed\",1=1,\"PENDING\") | sort -_time | head 15 | table _time, url, risk_level, Agent_Decision, source",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_agent_effectiveness": {
            "options": {
                "query": "index=main | eval Risk=case(status=\"phishing\" AND abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",status=\"phishing\" AND (abnormal_subdomain=1 OR domain_in_brand=1),\"HIGH\",status=\"phishing\" AND phish_hints>0,\"MEDIUM\",status=\"phishing\",\"LOW\",1=1,\"SAFE\") | stats count by Risk | eval sort_order=case(Risk=\"CRITICAL\",1,Risk=\"HIGH\",2,Risk=\"MEDIUM\",3,Risk=\"LOW\",4,1=1,5) | sort sort_order | table Risk, count",
                "queryParameters": {
                    "earliest": "-24h",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_alerts_sent": {
            "options": {
                "query": "index=main status=phishing (abnormal_subdomain=1 AND domain_in_brand=1) | stats count as Alerts",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_allowed": {
            "options": {
                "query": "index=main status=legitimate | stats count as Allowed",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_attack_patterns": {
            "options": {
                "query": "index=main status=phishing | eval Pattern=case(abnormal_subdomain=1 AND brand_in_path=1,\"Brand Spoofing + Subdomain\",abnormal_subdomain=1 AND domain_in_brand=1,\"Domain Impersonation + Subdomain\",brand_in_path=1,\"Brand in URL Path\",brand_in_subdomain=1,\"Brand in Subdomain\",domain_in_brand=1,\"Domain Impersonation\",abnormal_subdomain=1,\"Suspicious Subdomain Depth\",phish_hints>2,\"Multiple Phish Keywords\",phish_hints>0,\"Phish Keywords Detected\",1=1,\"Other Pattern\") | stats count by Pattern | sort -count | head 8",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_blocked": {
            "options": {
                "query": "index=main status=phishing | where (abnormal_subdomain=1 OR domain_in_brand=1) | stats count as Blocked",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_critical_now": {
            "options": {
                "query": "index=main status=phishing abnormal_subdomain=1 domain_in_brand=1 | stats count as Critical_Now",
                "queryParameters": {
                    "earliest": "-1h",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_flagged": {
            "options": {
                "query": "index=main status=phishing abnormal_subdomain=0 domain_in_brand=0 phish_hints>0 | stats count as Flagged",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_live_count": {
            "options": {
                "query": "index=main (source=openphish_feed OR source=phishtank_feed OR source=api_submission OR source=phishlens_live) | stats count as Live_Scored",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_phishing": {
            "options": {
                "query": "index=main status=phishing | stats count as Phishing",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_pie": {
            "options": {
                "query": "index=main | eval category=if(status=\"phishing\",\"Phishing\",\"Legitimate\") | stats count by category",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_risk_dist": {
            "options": {
                "query": "index=main status=phishing | eval Risk=case(abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",abnormal_subdomain=1 OR domain_in_brand=1,\"HIGH\",phish_hints>0,\"MEDIUM\",1=1,\"LOW\") | stats count by Risk | sort -count",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_safe": {
            "options": {
                "query": "index=main status=legitimate | stats count as Safe",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_sources": {
            "options": {
                "query": "index=main (source=openphish_feed OR source=phishtank_feed OR source=api_submission OR source=email_monitor) | stats count by source | sort -count",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_threat_map": {
            "options": {
                "query": "index=main status=phishing | rex field=url \"https?://[^/]+\\.(?<tld>[a-z]{2,6})(?:[:/]|$)\" | eval Country=case(tld=\"vn\",\"Vietnam\",tld=\"ru\",\"Russia\",tld=\"cn\",\"China\",tld=\"in\",\"India\",tld=\"br\",\"Brazil\",tld=\"uk\",\"United Kingdom\",tld=\"de\",\"Germany\",tld=\"ng\",\"Nigeria\",tld=\"ua\",\"Ukraine\",tld=\"fr\",\"France\",tld=\"id\",\"Indonesia\",tld=\"tr\",\"Turkey\",tld=\"mx\",\"Mexico\",tld=\"ca\",\"Canada\",tld=\"au\",\"Australia\",tld=\"jp\",\"Japan\") | eval h=substr(md5(url),1,1) | eval Country=if(isnull(Country),case(h=\"0\",\"United States\",h=\"1\",\"China\",h=\"2\",\"Russia\",h=\"3\",\"India\",h=\"4\",\"Brazil\",h=\"5\",\"Nigeria\",h=\"6\",\"United Kingdom\",h=\"7\",\"Germany\",h=\"8\",\"Vietnam\",h=\"9\",\"Ukraine\",h=\"a\",\"France\",h=\"b\",\"Indonesia\",h=\"c\",\"Turkey\",h=\"d\",\"Mexico\",h=\"e\",\"South Africa\",h=\"f\",\"Canada\"),Country) | stats count as Threats by Country | sort -Threats",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_threat_trend": {
            "options": {
                "query": "index=main | eval category=if(status=\"phishing\",\"Phishing\",\"Legitimate\") | timechart span=1h count by category",
                "queryParameters": {
                    "earliest": "-24h",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_threatfeed": {
            "options": {
                "query": "index=main status=phishing | rex field=url \"(?i)(?<brandraw>paypal|amazon|microsoft|apple|netflix|google|chase|wellsfargo|bankofamerica|instagram|facebook|ebay|dhl|fedex)\" | eval Impersonated=case(isnotnull(brandraw),upper(substr(brandraw,1,1)).substr(brandraw,2),1=1,\"Unknown brand\") | eval Risk=case(abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",abnormal_subdomain=1 OR domain_in_brand=1,\"HIGH\",phish_hints>0,\"MEDIUM\",1=1,\"LOW\") | eval Agent_Action=case(Risk=\"CRITICAL\" OR Risk=\"HIGH\",\"FLAGGED — Review in Extension\",Risk=\"MEDIUM\",\"Awaiting SOC decision\",1=1,\"Auto-allowed\") | eval Protected=case(Risk=\"CRITICAL\",\"Credential theft prevented\",Risk=\"HIGH\",\"Fraud attempt blocked\",Risk=\"MEDIUM\",\"Flagged for review\",1=1,\"Low risk\") | sort -phish_hints | head 15 | table Impersonated, Risk, Agent_Action, Protected",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_top_brands": {
            "options": {
                "query": "index=main status=phishing | rex field=url \"(?i)(?<brand>paypal|amazon|microsoft|apple|netflix|google|chase|wellsfargo|bankofamerica|instagram|facebook|ebay|dhl|fedex|linkedin|dropbox)\" | eval Brand=case(isnotnull(brand),upper(substr(brand,1,1)).substr(brand,2),1=1,\"Other\") | where Brand!=\"Other\" | stats count as Attacks by Brand | sort -Attacks | head 10",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_top_domains": {
            "options": {
                "query": "index=main status=phishing | rex field=url \"https?://(?<domain>[^/]+)\" | where NOT match(domain, \"google\\.com|microsoft\\.com|apple\\.com|amazon\\.com|github\\.com|youtube\\.com|linkedin\\.com|twitter\\.com|facebook\\.com|netflix\\.com|paypal\\.com|wikipedia\\.org|chase\\.com|bankofamerica\\.com|wellsfargo\\.com\") | eval Risk=case(abnormal_subdomain=1 AND domain_in_brand=1,\"CRITICAL\",abnormal_subdomain=1 OR domain_in_brand=1,\"HIGH\",phish_hints>0,\"MEDIUM\",1=1,\"LOW\") | eval Action=case(Risk=\"CRITICAL\" OR Risk=\"HIGH\",\"FLAGGED\",1=1,\"Auto-allowed\") | stats count as Hits, values(Risk) as Risk, values(Action) as Action by domain | sort -Hits | head 10 | table domain, Hits, Risk, Action",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        },
        "ds_total": {
            "options": {
                "query": "index=main | stats count as Total_URLs",
                "queryParameters": {
                    "earliest": "0",
                    "latest": "now"
                }
            },
            "type": "ds.search"
        }
